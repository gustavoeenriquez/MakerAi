# ============================================================
# MakerAI - Archivo de configuración de API Keys
# ============================================================
# Este archivo es un método alternativo al registro de
# API Keys como variables de entorno en Windows o Linux.
#
# INSTRUCCIONES:
# 1. Renombrar este archivo de ".env.example" a ".env"
# 2. Quitar el # de las API Keys que vayas a utilizar
# 3. Reemplazar "Tu_APIKey_De_..." por tu API Key
# ============================================================

#OPENAI_API_KEY=Tu_APIKey_De_OpenAI
#GEMINI_API_KEY=Tu_APIKey_De_Gemini
#CLAUDE_API_KEY=Tu_APIKey_De_Claude
#COHERE_API_KEY=Tu_APIKey_De_Cohere
#MISTRAL_API_KEY=Tu_APIKey_De_Mistral
#DEEPSEEK_API_KEY=Tu_APIKey_De_DeepSeek
#GROQ_API_KEY=Tu_APIKey_De_Groq
#GROK_API_KEY=Tu_APIKey_De_Grok
#KIMI_API_KEY=Tu_APIKey_De_Kimi
#OLLAMA_CLOUD_API_KEY=Tu_APIKey_De_Ollama

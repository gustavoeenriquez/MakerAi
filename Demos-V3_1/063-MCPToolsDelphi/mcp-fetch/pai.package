[package]
name = mcp-fetch
version = 1.0.1
description = HTTP GET fetch MCP server. Retrieves web pages and REST API content as plain text.
author = MakerAI
license = MIT
tags = mcp,http,fetch,web,delphi
homepage = https://makerai.cimamaker.com
min_pai_version = 1.0.0

[mcp]
entrypoint = mcp-fetch.exe
protocol = stdio

[tools]
names = fetch

[platform]
windows = true
linux = false
macos = false

[package]
name = mcp-git
version = 1.0.1
description = Git operations MCP server. Execute any git command and capture its output. Includes git clone support.
author = MakerAI
license = MIT
tags = mcp,git,vcs,delphi
homepage = https://makerai.cimamaker.com
min_pai_version = 1.0.0

[mcp]
entrypoint = mcp-git.exe
protocol = stdio

[tools]
names = git_command,git_clone

[platform]
windows = true
linux = false
macos = false

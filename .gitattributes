# Recursos compilados
*.res binary
*.dcr binary

# Imágenes
*.bmp binary
*.ico binary
*.jpg binary
*.png binary
*.gif binary

# Documentos de oficina
*.pdf  binary
*.docx binary
*.xlsx binary

# Audio
*.m4a binary

# Diseño gráfico

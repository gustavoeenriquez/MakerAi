# Configuración por defecto
* text=auto

# ============================================================
# Archivos de código fuente (normalizar finales de línea)
# ============================================================
*.pas text
*.inc text
*.rc  text

# Archivos de formularios y diseño visual
*.dfm text
*.fmx text
*.lfm text

# Archivos de proyecto principal
*.dpr text
*.dpk text

# Documentación y configuración
*.txt      text
*.md       text
*.xml      text
*.graphml  text
*.example  text
*.mcpconf  text

# Archivos MakerAI (JSON)
*.mkai text

# ============================================================
# Archivos de proyecto (NO convertir - mantener CRLF nativo)
